# Cesium Ion Access Token — get yours at https://ion.cesium.com
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Optional API settings for local development:
# 1) Leave both unset: use Vite dev proxy /api -> http://172.30.106.121:8080
# 2) Set VITE_API_BASE_URL=http://your-backend:8080 to access a real backend directly
#    (the frontend will automatically append /api)
# 3) Set VITE_API_MODE=mock for front-end only development with built-in local mock data
#    This avoids Vite proxy timeout logs when the backend is unavailable.
# VITE_API_MODE=mock
# VITE_API_BASE_URL=http://127.0.0.1:8080
