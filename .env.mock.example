# 推荐：DashScope / 千问 OpenAI 兼容模式
# 官方兼容模式基础地址：
# https://dashscope.aliyuncs.com/compatible-mode/v1

# 可以只配一个公共 Key
SATOPS_LLM_API_KEY=your_qwen_api_key

# 也支持直接读取 DashScope 变量名
# DASHSCOPE_API_KEY=your_qwen_api_key

# 如果协调器和专家想用不同密钥，也可以单独配置
# SATOPS_COORDINATOR_API_KEY=your_coordinator_api_key
# SATOPS_SPECIALIST_NETWORK_API_KEY=your_specialist_api_key

# 说明：
# 1. 把本文件复制为 .env.mock
# 2. 把上面的 key 改成真实值
# 3. 重启 node mock-server.cjs
