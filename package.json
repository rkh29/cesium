{
  "name": "tmxt-communication",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "vue-tsc && vite build",
    "build:electron": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder -w nsis",
    "build:zip": "npm run build && electron-builder -w zip",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cesium": "^1.138.0",
    "dayjs": "^1.11.19",
    "echarts": "^5.5.1",
    "element-plus": "^2.8.7",
    "pinia": "^2.2.6",
    "three": "^0.183.2",
    "vite-plugin-cesium": "^1.2.23",
    "vue": "^3.4.13",
    "vue-router": "^4.4.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "electron": "^27.0.0",
    "electron-builder": "^24.13.3",
    "express": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vue-tsc": "^2.1.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.tmxt.desktop",
    "productName": "天马星通通信控制平台",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "天马星通通信控制平台",
      "createDesktopShortcut": true
    }
  }
}
